# ── ThreatLens Server — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your real keys.
# NEVER commit .env — it is listed in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# VirusTotal API key (free tier at https://www.virustotal.com/gui/join-us)
VIRUS_TOTAL_API_KEY=your_virustotal_api_key_here

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional — leave blank to skip those checks ───────────────────────────────

# AbuseIPDB — IP reputation & abuse reports (https://www.abuseipdb.com/register)
ABUSEIPDB_API_KEY=

# URLScan.io — submit URLs for sandbox scanning (https://urlscan.io/user/signup)
URLSCAN_API_KEY=

# URLhaus & ThreatFox (abuse.ch) require NO API key — always active
